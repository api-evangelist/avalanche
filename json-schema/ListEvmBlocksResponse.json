{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalanche/main/json-schema/ListEvmBlocksResponse.json",
  "title": "ListEvmBlocksResponse",
  "type": "object",
  "properties": {
    "nextPageToken": {
      "type": "string",
