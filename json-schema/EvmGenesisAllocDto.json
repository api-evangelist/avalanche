{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalanche/main/json-schema/EvmGenesisAllocDto.json",
  "title": "EvmGenesisAllocDto",
  "type": "object",
  "properties": {
    "balance": {
      "type": "string",
