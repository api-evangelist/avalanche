{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalanche/main/json-schema/NftTokenMetadataStatus.json",
  "title": "NftTokenMetadataStatus",
  "type": "string",
  "description": "The metadata indexing status of the nft.",
