{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalanche/main/json-schema/EvmGenesisWarpConfigDto.json",
  "title": "EvmGenesisWarpConfigDto",
  "type": "object",
  "properties": {
    "blockTimestamp": {
      "type": "number",
